<Application x:Class="EstimateApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:EstimateApp.Converters"
             xmlns:local="clr-namespace:EstimateApp">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <md:BundledTheme BaseTheme="Light" PrimaryColor="DeepPurple" SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
            <conv:IntToVisibilityConverter x:Key="IntToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
